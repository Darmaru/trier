<idea-plugin>
    <id>com.darmaru.trier</id>
    <name>Trier - Tailwind CSS Class Sorter</name>
    <vendor url="https://github.com/Darmaru">Darmaru</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>JavaScript</depends>
    <depends>NodeJS</depends>
    <depends optional="true" config-file="trier-vue.xml">org.jetbrains.plugins.vue</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable
                id="settings.trier"
                displayName="Trier"
                parentId="tools"
                instance="com.darmaru.trier.settings.TrierSettingsConfigurable"/>
        <notificationGroup id="Trier" displayType="BALLOON" isLogByDefault="true"/>
    </extensions>

    <applicationListeners>
        <listener
                class="com.darmaru.trier.listeners.TrierSaveListener"
                topic="com.intellij.openapi.fileEditor.FileDocumentManagerListener"/>
        <listener
                class="com.darmaru.trier.listeners.TrierActionListener"
                topic="com.intellij.openapi.actionSystem.ex.AnActionListener"/>
    </applicationListeners>

    <actions>
        <action
                id="Trier.SortCurrent"
                class="com.darmaru.trier.actions.SortTailwindInEditorAction"
                text="Sort Tailwind Classes"
                description="Sort Tailwind classes in the current file or selection"
                icon="/icons/trier.svg">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action
                id="Trier.SortProjectView"
                class="com.darmaru.trier.actions.SortTailwindInProjectViewAction"
                text="Sort Tailwind Classes"
                description="Preview Tailwind class sorting for the selected file or folder"
                icon="/icons/trier.svg">
            <add-to-group
                    group-id="ProjectViewPopupMenuModifyGroup"
                    anchor="after"
                    relative-to-action="ReformatCode"/>
        </action>
        <action
                id="Trier.SortFolder"
                class="com.darmaru.trier.actions.SortTailwindInFolderAction"
                text="Sort Tailwind Classes in Folder..."
                description="Sort Tailwind classes in a folder using a custom glob pattern"
                icon="/icons/trier.svg">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
