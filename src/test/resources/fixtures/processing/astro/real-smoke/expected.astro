---
import Button from "../components/Button.astro"

const { class: className = "", compact = false, active = false } = Astro.props
const variants = {
  shell: cn("flex bg-red-500 p-4 text-center font-bold"),
  button: cn([
    "flex bg-red-500 p-4 text-center font-bold",
    active && "flex p-4 font-bold",
    { "px-2 py-0.5 text-xs tracking-wide": compact },
  ]),
  unsafe: cn(`text-center ${activeClass} p-4 flex bg-red-500 font-bold`),
}
---

<main
  class={active ? "flex bg-red-500 p-4 text-center font-bold" : "flex p-4 font-bold"}
  className={"flex bg-red-500 p-4 text-center font-bold"}
>
  <Button
    class:list={[
      variants.shell,
      className,
      "flex p-4 font-bold",
      ["px-2 py-0.5 text-xs tracking-wide"],
      { "px-2 py-0.5 text-xs tracking-wide": compact },
    ]}
  >
    Save
  </Button>
  <Card className={`text-center ${activeClass} p-4 flex bg-red-500 font-bold`} />
</main>

<style>
  .button {
    @apply flex bg-red-500 p-4 text-center font-bold;
  }
</style>
