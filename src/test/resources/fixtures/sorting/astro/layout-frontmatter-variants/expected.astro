---
import Button from "../components/Button.astro"

const { class: className = "", compact = false, active = false } = Astro.props
const variants = {
  shell: cn("flex bg-red-500 p-4 text-center font-bold"),
  button: cn([
    "flex bg-red-500 p-4 text-center font-bold",
    active && "flex p-4 font-bold",
    { "px-2 py-0.5 text-xs tracking-wide": compact },
  ]),
}
---

<main class:list={[variants.shell, className]}>
  <Button class:list={[variants.button, "flex p-4 font-bold"]}>Save</Button>
</main>
